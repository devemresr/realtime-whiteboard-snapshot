{
	"compilerOptions": {
		"rootDir": "..",
		"outDir": "./dist",
		"module": "node16",
		"moduleResolution": "node16",
		"target": "es2022",
		"lib": ["es2022"],
		"types": ["node"],
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"strict": true,
		"isolatedModules": true,
		"moduleDetection": "force",
		"skipLibCheck": true,
		"esModuleInterop": true,
		"paths": {
			"@/types": ["./server/types"]
		}
	},
	"include": ["server/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
